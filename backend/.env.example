# 金典软装ERP - 环境配置
# 复制此文件为 .env 并修改配置

# 数据库
DATABASE_URL=sqlite+aiosqlite:///./data/jindian.db
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/jindian

# JWT
JWT_SECRET=change-this-to-a-random-secret-key-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=72

# CORS（逗号分隔）
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8000

# 门店信息
STORE_NAME=金典软装
STORE_PHONE=0571-xxxx-xxxx

# 日志级别
LOG_LEVEL=INFO
