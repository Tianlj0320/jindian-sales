# ── 金典软装ERP V4.0 环境配置 ──────────────────────
# 将此文件复制为 .env 并修改实际值
# 注意：.env 不应提交到 Git 仓库

# 数据库
# DATABASE_URL=sqlite+aiosqlite:///./data/jindian.db
# DB_ECHO=false

# JWT 密钥（生产环境务必替换为随机字符串）
JWT_SECRET=jindian-erp-v4-dev-secret-key-2026

# 跨域（逗号分隔）
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8000

# 日志
LOG_LEVEL=INFO
